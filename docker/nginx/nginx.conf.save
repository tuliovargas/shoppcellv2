server {
    listen 80;
    index index.php index.html;
    root /var/www/public;    server_name app.lojashoppcell.com.br www.lojashoppcell.com.br;

    location = /favicon.ico { access_log off; log_not_found off; }
    location = /robots.txt  { access_log off; log_not_found off; }    

    ssl_certificate /etc/ssl/certs/app.lojashoppcell.com.br.pem
    ssl_certificate_key /etc/ssl/certs/app.lojashoppcell-key.com.br.pem
    ssl_client_certificate /etc/ssl/certs/origin-pull.ca.pem
    ssl_verify_client on

    client_max_body_size 51g;
    client_body_buffer_size 1m;
    client_body_in_file_only clean;

    location ~ \.php$ {
        try_files $uri =404;
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass app:9000;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param PATH_INFO $fastcgi_path_info;
    }

    location / {
        try_files $uri $uri/ /index.php?$query_string;
        gzip_static on;
    }
}
