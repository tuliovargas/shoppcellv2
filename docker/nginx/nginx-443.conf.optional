server {
    listen 443 ssl http2;
    server_name app.lojashoppcell.com.br localhost;
    ssl_certificate     /etc/nginx/ssl/custom/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/custom/privkey.pem;
    ssl_session_timeout 1d;
    ssl_session_cache shared:SSL:10m;

    index index.php index.html;
    root /var/www/public;

    include /var/www/docker/nginx/laravel-php.inc;
}
