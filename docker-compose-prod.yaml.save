version: "3.7"

services:
  app:
    build: docker/app
    container_name: app
    entrypoint: ./docker/app/entrypoint.sh
    restart: always
    volumes:
      - .:/var/www
      - ./docker/app/prod.ini:/usr/local/etc/php/conf.d/custom.ini
      - "/etc/timezone:/etc/timezone:ro"
      - "/etc/localtime:/etc/localtime:ro"
    networks:
      - app-network
    depends_on:
      - db

  nginx:
    build: docker/nginx
    container_name: nginx
    entrypoint: ./docker/nginx/entrypoint.sh
    restart: always
    tty: true
    ports:
      - "80:80"
      - "443:443"
    environment:
      WAIT: -wait tcp://app:9000
    volumes:
      - .:/var/www
      - "/etc/timezone:/etc/timezone:ro"
      - 
      - "/etc/localtime:/etc/localtime:ro"
    networks:
      - app-network
    depends_on:
      - app

  db:
    build: docker/mariadb
    command: mysqld --default-authentication-plugin=mysql_native_password
    container_name: db
    restart: always
    tty: true
    ports:
      - "3306:3306"
    volumes:
      - ./docker/dumps:/tmp
      - ./docker/dbdata:/var/lib/mysql
      - ./docker/mysql:/docker-entrypoint-initdb.d
      - "/etc/timezone:/etc/timezone:ro"
      - "/etc/localtime:/etc/localtime:ro"
    environment:
      - MYSQL_DATABASE=env_db
      - MYSQL_ROOT_PASSWORD=root
    networks:
      - app-network

  phpmyadmin:
    build: docker/pma
    restart: always
    container_name: shopping-phpmyadmin
    depends_on:
      - db
    ports:
      - 8081:80
    volumes:
      - ./docker/pma:/var/www/app/
    environment:
      - PMA_USER=root
      - PMA_PASSWORD=root
      - PMA_HOST=db
      - MYSQL_ROOT_PASSWORD=root
      - PMA_ARBITRARY=1
      - PMA_PORT=3306
      - UPLOAD_LIMIT=64M
    networks:
      - app-network

networks:
  app-network:
    driver: bridge
