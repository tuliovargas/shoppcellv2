version: "3.7"

services:
  app:
    build: docker/app
    container_name: app
    entrypoint: ./docker/app/entrypoint.sh
    restart: always
    volumes:
      - .:/var/www
      - ./docker/app/dev.ini:/usr/local/etc/php/conf.d/custom.ini
      - "/etc/timezone:/etc/timezone:ro"
      - "/etc/localtime:/etc/localtime:ro"
    networks:
      - app-network
    depends_on:
      - db

  node:
    build: docker/node
    container_name: node
    restart: always
    ports:
      - "3000:3000"
      - "35729:35729"
    volumes:
      - .:/home/node/app
    networks:
      - app-network

  nginx:
    build: docker/nginx
    container_name: nginx
    entrypoint: ./docker/nginx/entrypoint.sh
    restart: always
    tty: true
    ports:
      - "8000:80"
    environment:
      WAIT: -wait tcp://app:9000
    volumes:
      - .:/var/www
      - "/etc/timezone:/etc/timezone:ro"
      - "/etc/localtime:/etc/localtime:ro"
    networks:
      - app-network
    depends_on:
      - app


hpmyadmin:
    build: docker/pma
    restart: always
    container_name: shopping-phpmyadmin
    depends_on:
      - db
    ports:
      - 8081:80
    volumes:
      - ./docker/pma:/var/www/app/
    environment:
      - PMA_HOST=db
      - MYSQL_ROOT_PASSWORD=root
      - PMA_ARBITRARY=1
      - PMA_PORT=3306
    networks:
      - app-network

networks:
  app-network:
    driver: bridge
